{
  "name": "@pixelmind/sdk",
  "version": "0.1.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Render-aware feedback loop SDK for LLM-generated UI",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "keywords": [
    "ai",
    "llm",
    "design",
    "vision",
    "vibe-coding",
    "ui-feedback",
    "design-system"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bitjaru/pixelmind"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "openai": "^6.38.0",
    "playwright": "^1.49.0"
  }
}
